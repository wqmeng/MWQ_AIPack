package MWQ_AI;

{$R *.res}
{$IFDEF IMPLICITBUILDING This IFDEF should not be used by users}
{$ALIGN 8}
{$ASSERTIONS ON}
{$BOOLEVAL OFF}
{$DEBUGINFO OFF}
{$EXTENDEDSYNTAX ON}
{$IMPORTEDDATA ON}
{$IOCHECKS ON}
{$LOCALSYMBOLS ON}
{$LONGSTRINGS ON}
{$OPENSTRINGS ON}
{$OPTIMIZATION OFF}
{$OVERFLOWCHECKS ON}
{$RANGECHECKS ON}
{$REFERENCEINFO ON}
{$SAFEDIVIDE OFF}
{$STACKFRAMES ON}
{$TYPEDADDRESS OFF}
{$VARSTRINGCHECKS ON}
{$WRITEABLECONST OFF}
{$MINENUMSIZE 1}
{$IMAGEBASE $400000}
{$DEFINE DEBUG}
{$ENDIF IMPLICITBUILDING}
{$IMPLICITBUILD ON}

requires
  rtl;

contains
  MWQ.Ollama.PromptBuilder in '..\..\src\Ollama\MWQ.Ollama.PromptBuilder.pas',
  MWQ.Ollama.ResponseParser in '..\..\src\Ollama\MWQ.Ollama.ResponseParser.pas',
  MWQ.Ollama.Types in '..\..\src\Ollama\MWQ.Ollama.Types.pas',
  MWQ.Ollama.Manager in '..\..\src\Ollama\MWQ.Ollama.Manager.pas';

end.
